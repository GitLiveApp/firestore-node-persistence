    "test": "npm run build && node --test --disable-warning=ExperimentalWarning \"test/*.test.js\"",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "firebase": "^12.0.0",
    "typescript": "^5.5.0"
